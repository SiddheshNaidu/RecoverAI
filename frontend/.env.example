# RecoverAI Frontend — Environment Variables
# Copy to `.env` or `.env.local`. Backend secrets live in `backend/.env` (see `backend/.env.example`).

# Backend base URL (must match `uvicorn` port, usually 8000). Leave empty to use Vite dev proxy only.
VITE_API_URL=http://localhost:8000

# Supabase (Project Settings → API) — used by frontend/src/api/db.js
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
